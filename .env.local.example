# ─── Supabase ─────────────────────────────────────────────────────────────────
# Lấy từ: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Cách lấy keys ────────────────────────────────────────────────────────────
# 1. Vào https://supabase.com → tạo project mới (free)
# 2. Vào Project → Settings → API
# 3. Copy "Project URL"          → NEXT_PUBLIC_SUPABASE_URL
# 4. Copy "anon public"          → NEXT_PUBLIC_SUPABASE_ANON_KEY
# 5. Copy "service_role secret"  → SUPABASE_SERVICE_ROLE_KEY
#
# ⚠️  SERVICE_ROLE_KEY có full quyền DB — KHÔNG commit lên git!
#     File .env.local đã được .gitignore bỏ qua tự động.
